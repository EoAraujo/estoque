# Copie este arquivo para .env e ajuste os valores

# Chave secreta do Django - gere uma nova para produção com:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=troque-por-uma-chave-segura-em-producao
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0,testserver,64.181.168.121

# Banco: deixe vazio ou aponte para sqlite local; ou use PostgreSQL:
#   DATABASE_URL=postgres://usuario:senha@localhost:5432/estoque
# O sistema detecta automaticamente (psycopg + dj_database_url)
DATABASE_URL=

# VAPID (Web Push) - opções:
# 1. Chaves em variáveis de ambiente (menos recomendado para PEM)
#    VAPID_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."
#    VAPID_PUBLIC_KEY=abc123...
#
# 2. Chaves em arquivos (recomendado para produção)
#    Gere com: ./generate_vapid.sh
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY_FILE=
VAPID_PUBLIC_KEY_FILE=
VAPID_CLAIMS_SUB=mailto:admin@estoque.local

# CSRF trusted origins (produção) - separado por virgula
# Exemplo: 64.181.168.121,estoque.seudominio.com
CSRF_TRUSTED_ORIGINS=64.181.168.121

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
